# ── LLM ────────────────────────────────────────────────────────────────────────
# Required. Used by the LLM reasoning node (Node 5).
OPENAI_API_KEY=sk-...

# Optional. Switch to Azure OpenAI for production deployments.
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# OPENAI_API_VERSION=2024-02-01

# ── LangSmith observability ────────────────────────────────────────────────────
# Optional but strongly recommended. Traces every node execution.
# Sign up at https://smith.langchain.com to get a free API key.
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=aml-investigation-agent

# ── Agent config ───────────────────────────────────────────────────────────────
# Path to the SQLite database created by data/seed_data.py
DB_PATH=data/mock_transactions.db

# Path to the mock watchlist file
WATCHLIST_PATH=data/watchlist.json

# LLM model to use (override for Azure deployments)
LLM_MODEL=gpt-4o
